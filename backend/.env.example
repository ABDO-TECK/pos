# ════════════════════════════════════════════════════════════════
# POS System — Environment Configuration (Example)
# ════════════════════════════════════════════════════════════════
# كيفية الاستخدام:
#   1. انسخ هذا الملف:  copy .env.example .env
#   2. عدّل القيم أدناه حسب بيئتك
#   3. لا تُضف .env إلى Git (مُدرج في .gitignore)
# ════════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=pos_db
DB_USER=root
DB_PASS=your_secure_password_here
DB_CHARSET=utf8mb4

# ── Application ────────────────────────────────────────────────
# APP_ENV: development | production
APP_ENV=production
APP_DEBUG=false

# ── Auth Token ─────────────────────────────────────────────────
# مدة صلاحية التوكن بالثواني (604800 = أسبوع)
TOKEN_LIFETIME=604800

# ── Inventory ──────────────────────────────────────────────────
# حد المخزون المنخفض الافتراضي (يمكن تعديله من إعدادات المتجر)
LOW_STOCK_THRESHOLD=5

# ── Tax ────────────────────────────────────────────────────────
TAX_RATE=0.15

# ── Frontend ───────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"

# ── QZ Tray (Thermal Printing) ─────────────────────────────────
# المسار الكامل لملف المفتاح الخاص (private-key.pem) لتوقيع طباعة QZ Tray.
#
# ⚠️  قواعد أمان مهمة:
#   - يجب أن يكون الملف خارج مجلد المشروع (خارج htdocs)
#   - لا تُوقع الملف في Git أبداً
#   - تأكد من أن صلاحيات الملف 600 (مقروء من PHP فقط)
#
# مثال على مسارات آمنة:
#   Windows:  QZ_PRIVATE_KEY_PATH="C:/private/pos-keys/private-key.pem"
#   Linux:    QZ_PRIVATE_KEY_PATH="/etc/pos/private-key.pem"
#
# اتركه فارغاً للعمل في وضع الطباعة بدون توقيع (وضع التطوير):
#   QZ_PRIVATE_KEY_PATH=""
QZ_PRIVATE_KEY_PATH="C:/private/private-key.pem"
