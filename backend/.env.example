# ════════════════════════════════════════════════════════════════
# POS System — Environment Configuration (Example)
# ════════════════════════════════════════════════════════════════
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك:
#   copy .env.example .env
# ════════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=pos_db
DB_USER=root
DB_PASS=your_secure_password_here
DB_CHARSET=utf8mb4

# ── Application ────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false

# ── Auth Token ─────────────────────────────────────────────────
TOKEN_LIFETIME=604800

# ── Inventory ──────────────────────────────────────────────────
LOW_STOCK_THRESHOLD=5

# ── Tax ────────────────────────────────────────────────────────
TAX_RATE=0.15

# ── Frontend ───────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
